# Copy this file to .env in the same folder (PythonScripts/.env) and fill in values.
# ChatRouter / MemoryUpdater / HistoryCompactor load it automatically via python-dotenv.
# A project-root .env is also loaded as a fallback.
# Never commit real secrets.

# --- ChatRouter cloud last-resort (local coder/persona preferred) ---
# Budget tip: Claude Sonnet is costly. Prefer Gemini Flash Lite first, or disable cloud.
CLOUD_FALLBACK_ENABLED=true
# When false, keep local answers even if multi-file heuristics look incomplete (saves $).
CLOUD_ESCALATE_ON_INCOMPLETE=false
# When false, ignore ESCALATE_CLOUD markers from the local coder.
CLOUD_ESCALATE_ON_REQUEST=true
# Try providers in order until one succeeds (gemini first = cheaper)
CLOUD_FALLBACK_ORDER=gemini,claude

# Anthropic Claude (also accepts ANTHROPIC_API_KEY)
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
# Back-compat alias for GEMINI_MODEL
# CLOUD_INTEL_MODEL=gemini-2.5-flash-lite

# Names sent in OpenAI payloads (llama-server usually ignores these)
LOCAL_VOICE_MODEL=Qwen_Qwen3-14B-Q4_K_M.gguf
LOCAL_CODER_MODEL=Qwen3-Coder-30B-A3B-Instruct-Q4_K_M.gguf

# --- Local GGUFs (paths absolute OR relative to Brains/models/) ---
# PERSONA_MODEL_PATH=conversational/Qwen_Qwen3-14B-Q4_K_M.gguf
# CODER_MODEL_PATH=coding/Qwen3-Coder-30B-A3B-Instruct-Q4_K_M.gguf
#
# Second+ local coders: preferred ladder (tried in order before cloud when uncertain):
# CODER_MODELS=coding/Qwen3-Coder-30B-A3B-Instruct-Q4_K_M.gguf,coding/DeepSeek-Coder-V2-Lite-Instruct-Q4_K_M.gguf
#
# Or add just an alt after the primary (same effect as a 2-item ladder):
# CODER_ALT_MODEL_PATH=coding/DeepSeek-Coder-V2-Lite-Instruct-Q4_K_M.gguf
#
# Download any GGUF from Brains/:
#   .\add-model.ps1 -Preset deepseek-coder-v2-lite
#   .\add-model.ps1 -Role coding -Repo "owner/Some-GGUF" -File "Some-Q4_K_M.gguf"

# Bind address for the OpenAI-compatible router API
# Local only (default — safest; VS Code / Blossom Assistant on this PC):
CHAT_ROUTER_HOST=127.0.0.1
CHAT_ROUTER_PORT=8081
#
# Tailscale / remote clients (Postman, phone, another PC on your tailnet):
# - Set CHAT_ROUTER_HOST to this machine's Tailscale IPv4 (Tailscale app → machine → copy IP).
#   Example: CHAT_ROUTER_HOST=XXX.XXX.XXX.XXX
# - Prefer the Tailscale IP over 0.0.0.0 (0.0.0.0 listens on Wi‑Fi/LAN too; no auth on ChatRouter).
# - CHAT_ROUTER_PORT can be any free port (1024–65535); update clients to match.
# - Restart start-server.ps1 after changes. Test: GET http://<tailscale-ip>:<port>/health
# - You may need a Windows Firewall inbound rule for the port on Private/Tailscale networks.
# - llama-server stays on 127.0.0.1; only ChatRouter is exposed via Tailscale.

# --- LlamaServerManager hot-swap ---
LLAMA_SERVER_PORT=11434
PERSONA_CTX_SIZE=16384
CODER_CTX_SIZE=16384
LLAMA_N_GPU_LAYERS=999
# Persona chat: off skips Qwen3 long chain-of-thought (big speed win). Coder: auto/on.
PERSONA_REASONING=off
CODER_REASONING=auto
LLAMA_FLASH_ATTN=on

# --- Editor context packing (huge VS Code / Blossom dumps) ---
EDITOR_CONTEXT_PACK=true
# EDITOR_CONTEXT_BUDGET=12000
EDITOR_MAX_FILES=6
EDITOR_CHUNK_LINES=160
EDITOR_CHUNK_OVERLAP=20
EDITOR_REPO_KNOWLEDGE_CHARS=1200

# --- MemoryUpdater / CompanionEngine ---
REFLECTION_EVERY_N_TURNS=5

# --- SemanticMemory / ChromaDB ---
# CHROMA_DIR=
CHROMA_COLLECTION_LIFE=relationship_life
CHROMA_COLLECTION_CODING=coding_lessons
CHROMA_COLLECTION_LANGUAGE=language_lessons
CHROMA_COLLECTION_WEB=web_knowledge
MEMORY_TOP_K=5
# Drop memories below this importance when retrieving (demoted / junk).
MEMORY_MIN_IMPORTANCE=2

# --- Web search (learn → web_knowledge Chroma collection) ---
# Providers: duckduckgo (free, no key) | brave | serper (Google via Serper) | bing
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_MAX_RESULTS=5
# Also search on coding questions (not only when user says "google/look up")
WEB_SEARCH_ON_CODING=true
# BRAVE_SEARCH_API_KEY=
# SERPER_API_KEY=
# BING_SEARCH_API_KEY=

# --- Companion voice (Style-Bert-VITS2 → RVC; separate GPU service) ---
# When VOICE_ENABLED=true, start-server.ps1 launches Blossom/Voice on :8090.
VOICE_ENABLED=false
VOICE_SERVICE_URL=http://127.0.0.1:8090
VOICE_TIMEOUT_SEC=120
VOICE_MAX_CHARS=350
# heuristic (fast, default) | llm (extra local completion)
VOICE_EMOTION_MODE=heuristic
# Synthesize after text is queued so streaming isn't blocked
VOICE_DEFER_STREAM=true
# Default if client omits blossom_locale: ja | en
DEFAULT_CHAT_LOCALE=ja
VOICE_CACHE_DIR=../Mind/audio
# VOICE_DIR=  # optional; defaults to <project>/Voice
# VOICE_CHARACTERS_DIR=  # optional; defaults to <Voice>/characters
# Compact old SQLite chats into Chroma after llama boots (ChatRouter lifespan)
# COMPACT_ON_STARTUP=true
